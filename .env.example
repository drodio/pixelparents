# Copy to .env.local and fill in. .env.local is git-ignored and never committed.

# Cloudflare API token used to manage pixelparents.org DNS via flarectl.
# Scope: Zone:DNS:Edit on the pixelparents.org zone.
CLOUDFLARE_API_TOKEN=

# --- Developer API ---
# Neon Postgres connection string (Vercel Marketplace). Required for the API
# (key issuance/verification). Aggregate endpoints degrade to database:"pending"
# until the signup tables exist. Shared with the /signup feature.
DATABASE_URL=

# Resend — best-effort notifications. All optional; absence just skips email.
# Keep personal contact info HERE (env), never in the public source tree.
#   RESEND_FROM      verified sender, e.g. "Name <you@pixelparents.org>"
#   NOTIFY_TO        where admin notifications go (a real inbox)
#   EMAIL_SIGNATURE  multi-line block appended to every email (name/phone/etc.)
RESEND_API_KEY=
RESEND_FROM=
NOTIFY_TO=
EMAIL_SIGNATURE=

# ── Auth (Clerk) ─────────────────────────────────────────────────────────────
# From the Clerk dashboard (API Keys) or the Vercel Marketplace Clerk
# integration. Use Development-instance keys (pk_test/sk_test) locally; live
# (pk_live/sk_live) keys belong in Vercel's Production env.
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Where Clerk sends unauthenticated visitors to sign in.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# Comma-separated emails allowed into /admin (signed-in is not enough).
ADMIN_EMAILS=

# ── Links ────────────────────────────────────────────────────────────────────
# Absolute base URL used to build links in emails and secret share URLs
# (/p/<token>). Optional: falls back to the Vercel deployment URL, then
# https://pixelparents.org. Set in local dev to your tunnel/localhost if needed.
NEXT_PUBLIC_SITE_URL=

# Optional WhatsApp fallback shown on the student-verification widget — a wa.me
# link (e.g. https://wa.me/15551234567). Keep the real number OUT of the repo;
# set it here / in Vercel env. Absent → the WhatsApp option is simply hidden.
NEXT_PUBLIC_DRODIO_WHATSAPP_URL=

# Optional phone number shown in the help menu's GitHub/community dialog — the
# number to text to be added to the builder group. Keep the real number OUT of
# the repo; set it here / in Vercel env. Absent → the number is omitted and the
# dialog just shows the WhatsApp link (never hardcode a phone number in source).
NEXT_PUBLIC_DRODIO_PHONE=

# ── GitHub admin automation ──────────────────────────────────────────────────
# When someone is made an app admin, invite their GitHub account (from their
# signup's github_username) as a repo collaborator. Fine-grained PAT scoped to
# the repo with Administration: write. Optional — absent just skips the invite.
GITHUB_ADMIN_TOKEN=
# owner/repo to manage collaborators on (defaults to drodio/pixelparents).
GITHUB_REPO=

# ── Changelog (/changelog) ───────────────────────────────────────────────────
# Auto-generates changelog entries from commits via an LLM (no-PII prompt).
# Dormant until a key is set. Preferred: VERCEL_AI_GATEWAY (Vercel AI Gateway
# key — one key, many models, billed via Vercel). Falls back to ANTHROPIC_API_KEY
# for a direct Anthropic call. Optional CHANGELOG_MODEL (gateway default
# "anthropic/claude-haiku-4-5"; direct default "claude-haiku-4-5-20251001").
# If you set CHANGELOG_MODEL, use the id format of the ACTIVE backend —
# "provider/model" for the gateway, bare model id for direct Anthropic.
VERCEL_AI_GATEWAY=
ANTHROPIC_API_KEY=
CHANGELOG_MODEL=
# Protects the email-notify cron (/api/cron/changelog-notify). Vercel cron sends
# `Authorization: Bearer $CRON_SECRET` automatically when this is set.
CRON_SECRET=

# ── Family verification flags (both OFF by default) ──────────────────────────
# Auto-link families by shared OHS student email. When "true", confirming a
# student verification (confirmStudentCode) merges ANY other family already
# carrying that exact student email into the oldest (canonical) family — repoints
# their parents + children, family-wide approves the canonical, and records an
# audit trail in extra.merges. Unset/anything-but-"true" → no merge happens and
# behavior is identical to today. See lib/family-merge.ts.
FAMILY_AUTOLINK_ENABLED=
# Forced verification gate. When "true", an authed user who HAS a signup but whose
# family has ZERO verified OHS students is redirected to /verify?required=1 from
# anywhere in the (authed) area (admins are exempt; /verify itself is never
# gated). Unset/anything-but-"true" → no gating, behavior is identical to today.
# See app/(authed)/layout.tsx.
FAMILY_FORCE_VERIFY=

# ── Sign in with Pixel Parents (OIDC provider) ───────────────────────────────
# RS256 private key (PKCS#8 PEM) used to SIGN ID tokens. Generate one with:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out oauth_key.pem
# then paste the FULL PEM (incl. the BEGIN/END lines) here. The public half is
# derived and published at /.well-known/jwks.json. If unset, the provider returns
# a clean "provider_not_configured" error (it never crashes). NEVER commit a real
# key — keep it in .env.local / Vercel env only.
OAUTH_PRIVATE_KEY=
# The issuer + endpoint base URL third-party clients pin (the `iss` claim and the
# discovery doc). No trailing slash. Falls back to the Vercel deployment URL, then
# http://localhost:3000 for local dev. e.g. https://pixelparents.org
OAUTH_ISSUER=

# ── Product analytics (PostHog) ──────────────────────────────────────────────
# Client-side analytics (pageviews + autocapture) via posthog-js. Config is read
# ONLY from these public env vars — the key is never hardcoded in source. If
# NEXT_PUBLIC_POSTHOG_KEY is absent, the provider is a complete no-op (nothing is
# initialized or captured), so local/dev without a key does nothing.
#   NEXT_PUBLIC_POSTHOG_KEY   PostHog project API key (starts with "phc_").
#   NEXT_PUBLIC_POSTHOG_HOST  Ingestion host. Defaults to https://us.i.posthog.com
#                             (US cloud). Set https://eu.i.posthog.com for EU, or
#                             your reverse-proxy origin.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
