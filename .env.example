# Copy to .env.local and fill in. .env.local is git-ignored and never committed.

# Cloudflare API token used to manage pixelparents.org DNS via flarectl.
# Scope: Zone:DNS:Edit on the pixelparents.org zone.
CLOUDFLARE_API_TOKEN=

# --- Developer API ---
# Neon Postgres connection string (Vercel Marketplace). Required for the API
# (key issuance/verification). Aggregate endpoints degrade to database:"pending"
# until the signup tables exist. Shared with the /signup feature.
DATABASE_URL=

# Resend — best-effort notifications. All optional; absence just skips email.
# Keep personal contact info HERE (env), never in the public source tree.
#   RESEND_FROM      verified sender, e.g. "Name <you@pixelparents.org>"
#   NOTIFY_TO        where admin notifications go (a real inbox)
#   EMAIL_SIGNATURE  multi-line block appended to every email (name/phone/etc.)
RESEND_API_KEY=
RESEND_FROM=
NOTIFY_TO=
EMAIL_SIGNATURE=

# ── Auth (Clerk) ─────────────────────────────────────────────────────────────
# From the Clerk dashboard (API Keys) or the Vercel Marketplace Clerk
# integration. Use Development-instance keys (pk_test/sk_test) locally; live
# (pk_live/sk_live) keys belong in Vercel's Production env.
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Where Clerk sends unauthenticated visitors to sign in.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# Comma-separated emails allowed into /admin (signed-in is not enough).
ADMIN_EMAILS=

# ── Links ────────────────────────────────────────────────────────────────────
# Absolute base URL used to build links in emails and secret share URLs
# (/p/<token>). Optional: falls back to the Vercel deployment URL, then
# https://pixelparents.org. Set in local dev to your tunnel/localhost if needed.
NEXT_PUBLIC_SITE_URL=

# Optional WhatsApp fallback shown on the student-verification widget — a wa.me
# link (e.g. https://wa.me/15551234567). Keep the real number OUT of the repo;
# set it here / in Vercel env. Absent → the WhatsApp option is simply hidden.
NEXT_PUBLIC_DRODIO_WHATSAPP_URL=

# ── GitHub admin automation ──────────────────────────────────────────────────
# When someone is made an app admin, invite their GitHub account (from their
# signup's github_username) as a repo collaborator. Fine-grained PAT scoped to
# the repo with Administration: write. Optional — absent just skips the invite.
GITHUB_ADMIN_TOKEN=
# owner/repo to manage collaborators on (defaults to drodio/pixelparents).
GITHUB_REPO=

# ── Changelog (/changelog) ───────────────────────────────────────────────────
# Auto-generates changelog entries from commits via an LLM (no-PII prompt).
# Dormant until a key is set. Preferred: VERCEL_AI_GATEWAY (Vercel AI Gateway
# key — one key, many models, billed via Vercel). Falls back to ANTHROPIC_API_KEY
# for a direct Anthropic call. Optional CHANGELOG_MODEL (gateway default
# "anthropic/claude-haiku-4-5"; direct default "claude-haiku-4-5-20251001").
# If you set CHANGELOG_MODEL, use the id format of the ACTIVE backend —
# "provider/model" for the gateway, bare model id for direct Anthropic.
VERCEL_AI_GATEWAY=
ANTHROPIC_API_KEY=
CHANGELOG_MODEL=
# Protects the email-notify cron (/api/cron/changelog-notify). Vercel cron sends
# `Authorization: Bearer $CRON_SECRET` automatically when this is set.
CRON_SECRET=
