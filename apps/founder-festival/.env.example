# ─────────────────────────────────────────────────────────────────────────────
# Founder Festival — environment variables
#
# Copy to .env.local and fill in. Vars are grouped REQUIRED (app won't run
# correctly without them) vs OPTIONAL (feature-gated or have sane defaults).
# Platform-provided vars (VERCEL_ENV, NEXT_RUNTIME) are NOT listed — Vercel sets
# them. Regenerate the "used vars" set with:
#   grep -rhoE "process\.env\.[A-Z_0-9]+" src/ scripts/ | sort -u
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED: Database (Neon Postgres) ───────────────────────────────────────
# Pooled URL for request paths; unpooled for migrations / long cron jobs.
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# ── REQUIRED: Auth (Clerk) ───────────────────────────────────────────────────
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# ── REQUIRED: AI + research ──────────────────────────────────────────────────
# Claude scoring runs through the Vercel AI Gateway; Exa powers web research.
AI_GATEWAY_API_KEY=
EXA_API_KEY=

# ── REQUIRED: Cron auth ──────────────────────────────────────────────────────
# Vercel Cron sends `Authorization: Bearer $CRON_SECRET`. Without it, cron
# routes 401 in production (a non-prod localhost bypass exists for dev only).
CRON_SECRET=
# Separate secret gating the weekly Majestic Million refresh route.
MM_REFRESH_SECRET=

# ── REQUIRED for billing: Stripe ─────────────────────────────────────────────
STRIPE_SECRET_KEY=
# From the Stripe dashboard webhook endpoint; verifies inbound webhook signatures.
STRIPE_WEBHOOK_SECRET=

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM="Founder Festival <hello@festival.so>"
# Where operator alerts (e.g. Stripe refund clawbacks) are sent.
ADMIN_ALERT_EMAIL=

# ── SMS (Twilio) ─────────────────────────────────────────────────────────────
# Use the SAME var names in every environment and let the VALUE differ per
# environment, so code reads them with no prod/test branching: set the LIVE
# Account SID + Auth Token in Vercel Production, and the TEST credentials in
# Preview + Development and your local .env.local so non-prod runs never send
# real messages. (Twilio test credentials have their own Test Account SID.)
# TWILIO_FROM_NUMBER is the sending number (E.164, e.g. +14155550100).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Operator SMS alerts: when a server error is reported (lib/report-server-error.ts)
# a text goes here IN ADDITION to the ADMIN_ALERT_EMAIL email — but only when all
# the Twilio vars above AND this recipient are set, so it effectively fires only
# in Production. E.164 format, e.g. +14155551234.
ADMIN_ALERT_PHONE=

# ── Admin access ─────────────────────────────────────────────────────────────
# Comma-separated verified-email allowlist for /admin and /api/admin/*. Leave
# empty to rely solely on hardcoded super-admins + DB-approved admins.
ADMIN_EMAILS=
# "on" | "1" | "true" enables credit reservation/charging for bulk scoring jobs.
# OFF by default — bulk scoring then does not touch credits.
ADMIN_CREDIT_ENFORCEMENT=

# ── Optional enrichment credentials ──────────────────────────────────────────
# Each enricher is skipped silently if its credential is missing. Wikipedia, YC,
# and domain-scoped Exa work without keys. GITHUB_TOKEN strongly recommended in
# prod (raises GitHub's 60→5000 req/hr; without it, scoring under-counts).
GITHUB_TOKEN=
PRODUCT_HUNT_TOKEN=
STACK_EXCHANGE_KEY=
# NFX Signal investor enrichment. signal.nfx.com → DevTools → Network → any
# api.signal.nfx.com request → Authorization header value (drop the "Bearer "
# prefix). ~6-month TTL; re-grab when scrapes start returning 401.
NFX_SIGNAL_TOKEN=
# Shared secret gating the admin NFX-token refresh page (/admin/nfx-refresh).
NFX_TOKEN_REFRESH_SECRET=
# AnyMailFinder — paid email lookup for the admin find-email flow.
ANYMAILFINDER_API_KEY=
# Luma — event sync (admin events → Luma).
LUMA_API_KEY=
# BrightData — LinkedIn + async dataset enrichment (Crunchbase, X, etc.).
BRIGHTDATA_API_KEY=
# EnrichLayer — LinkedIn profile fallback enricher.
ENRICHLAYER_API_KEY=
# Google Knowledge Graph entity lookup.
GOOGLE_API_KEY=
# Kaggle public API (Bearer, newer KGAT_… token) — data-science credibility.
KAGGLE_API_TOKEN=
# Libraries.io — open-source package/ownership signal.
LIBRARIESIO_API_KEY=
# USPTO Open Data Portal — patents-as-inventor technical-depth signal.
USPTO_API_KEY=
# Chief — investor/operator network enricher (token, project, per-run call budget).
CHIEF_API_TOKEN=
CHIEF_PROJECT_ID=
CHIEF_CALL_BUDGET=
# Per-enricher external-call timeout in ms (in-code default if unset).
ENRICHER_TIMEOUT_MS=
# Wall-clock timeout (ms) for standalone external calls via fetchWithTimeout
# (Luma, SMS, AnyMailFinder, BrightData, etc.). In-code default 15000 if unset.
EXTERNAL_FETCH_TIMEOUT_MS=

# ── Analytics (PostHog) — public, sent to the browser ────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
# PostHog server-side read API — powers the daily metrics digest cron. SECRET is
# a personal API (read) key; PROJECT_ID + API_HOST have in-code defaults.
POSTHOG_SECRET=
POSTHOG_PROJECT_ID=
POSTHOG_API_HOST=
# Recipient for the 3am-Pacific daily metrics digest email (default drodio@festival.so).
METRICS_DIGEST_EMAIL=
# Comma-separated emails whose PostHog persons are filtered out of the digest so
# your own/test browsing doesn't inflate the numbers. Defaults to drodio@gmail.com.
METRICS_EXCLUDE_EMAILS=
# Canonical site origin (used in emails, OG URLs, canonical profile links).
NEXT_PUBLIC_SITE_URL=

# ── Optional: scoring tuning ─────────────────────────────────────────────────
# SCORING_CASCADE: "single" | "binary" | "3-tier" model-escalation strategy.
SCORING_CASCADE=
# SCORING_EFFORT: reasoning effort knob for the scoring model.
SCORING_EFFORT=
# Score thresholds (0-100) below which the cascade escalates to a stronger model.
CASCADE_HAIKU_MIN=
CASCADE_SONNET_MIN=

# ── Optional: feature flags ──────────────────────────────────────────────────
CLAIM_WELCOME_EMAIL_ENABLED=
DEV_API_WELCOME_EMAIL_ENABLED=

# ── Optional: rate limits (per-IP daily unless noted; *_GLOBAL caps total/day) ─
# Each has an in-code default; set only to override.
EVAL_PER_DAY_LIMIT=
EVAL_GLOBAL_PER_DAY=
FIND_HANDLE_PER_DAY_LIMIT=
FIND_HANDLE_GLOBAL_PER_DAY=
REDEEM_PER_DAY_LIMIT=
REDEEM_GLOBAL_PER_DAY=
EMAIL_ELIGIBLE_PER_DAY_LIMIT=
EVENT_APPLY_PER_DAY_LIMIT=
EVENT_APPLY_GLOBAL_PER_DAY=
# Anti-relay: max event decision emails to a SINGLE recipient address per day
# (a real applicant gets ~1; caps an attacker spamming one victim). Default 5.
EVENT_EMAIL_PER_RECIPIENT_PER_DAY=
# Public developer API (/api/v1/*) limits.
API_SCORE_GLOBAL_PER_DAY=
API_LOOKUP_PER_DAY_LIMIT=
API_LEADERBOARD_PER_DAY_LIMIT=
API_RESOLVE_PER_DAY_LIMIT=
RESOLVE_GLOBAL_PER_DAY=
API_SEARCH_PER_DAY_LIMIT=
API_SEARCH_GLOBAL_PER_DAY=
API_EVENTS_PER_DAY_LIMIT=
API_EVENT_BADGES_PER_DAY_LIMIT=
API_INDUSTRIES_PER_DAY_LIMIT=
# Super-admin bearer API (/api/admin/*) per-day limit.
ADMIN_API_PER_DAY_LIMIT=
# Verify-to-own (claim attestation) per-day limit.
CLAIM_VERIFY_PER_DAY_LIMIT=

# ── Storage / inbound email ──────────────────────────────────────────────────
# Vercel Blob read/write token (event photos, generated images).
BLOB_READ_WRITE_TOKEN=
# Resend Inbound webhook (Svix) signing secret — verifies claim-reply mail. The
# webhook fails closed (503) until this is set. CLAIM_REPLY_TO is the reply-to
# address (e.g. reply@reply.festival.so) routed to the inbound webhook.
RESEND_INBOUND_SIGNING_SECRET=
CLAIM_REPLY_TO=

# ── Notes ────────────────────────────────────────────────────────────────────
# Some one-off scripts in scripts/ accept POSTGRES_URL_NON_POOLING or APPLY_DB_URL
# as a DB-URL fallback (and LIMIT / CONCURRENCY as batch knobs); not needed for
# the app itself.
